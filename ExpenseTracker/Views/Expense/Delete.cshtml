@model ExpenseTracker.Models.Expense
@{
    ViewData["Title"] = "Delete Expense";
}

<style>
    .form-page {
        min-height: 100vh;
        background: #0F0F1A;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .form-card {
        background: #141420;
        border: 1px solid #FF6B6B33;
        border-radius: 18px;
        padding: 40px;
        width: 100%;
        max-width: 480px;
    }

    .warning-icon {
        width: 56px;
        height: 56px;
        background: #FF6B6B22;
        border: 1px solid #FF6B6B44;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 20px;
    }

    .form-card h2 {
        color: #fff;
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .form-card h2 span {
        background: linear-gradient(90deg, #FF6B6B, #F97316);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .form-subtitle {
        color: #555;
        font-size: 13px;
        margin-bottom: 28px;
    }

    .detail-box {
        background: #0F0F1A;
        border: 1px solid #ffffff10;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 28px;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #ffffff08;
    }

    .detail-row:last-child { border-bottom: none; }

    .detail-label {
        color: #555;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .detail-value {
        color: #ccc;
        font-size: 14px;
        font-weight: 500;
        text-align: right;
    }

    .detail-value.amount {
        color: #FF6B6B;
        font-weight: 700;
        font-size: 16px;
    }

    .badge-category {
        background: #A78BFA22;
        color: #A78BFA;
        border: 1px solid #A78BFA33;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
    }

    .form-actions {
        display: flex;
        gap: 12px;
    }

    .btn-delete {
        flex: 1;
        background: linear-gradient(135deg, #FF6B6B, #F97316);
        color: #fff;
        border: none;
        padding: 13px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .btn-delete:hover { opacity: 0.85; }

    .btn-cancel {
        background: transparent;
        color: #aaa;
        border: 1px solid #ffffff18;
        padding: 13px 24px;
        border-radius: 10px;
        font-size: 14px;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
    }

    .btn-cancel:hover { color: #fff; border-color: #ffffff44; background: #ffffff0a; text-decoration: none; }
</style>

<div class="form-page">
    <div class="form-card">

        <div class="warning-icon">⚠️</div>

        <h2>Delete <span>Expense</span></h2>
        <p class="form-subtitle">This action cannot be undone. Are you sure?</p>

        <div class="detail-box">
            <div class="detail-row">
                <span class="detail-label">Title</span>
                <span class="detail-value">@Model.Title</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Amount</span>
                <span class="detail-value amount">₦@Model.Amount.ToString("N2")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Category</span>
                <span class="detail-value">
                    <span class="badge-category">@Model.Category</span>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Date</span>
                <span class="detail-value">@Model.Date.ToShortDateString()</span>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="form-actions">
                <button type="submit" class="btn-delete">Yes, Delete</button>
                <a asp-action="Index" class="btn-cancel">Cancel</a>
            </div>
        </form>

    </div>
</div>