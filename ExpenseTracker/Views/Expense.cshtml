@{
}

<h2>Expenses</h2>

<form asp-action="Expenses" method="get">
    <input type="text"
           name="searchTerm"
           class="form-control"
           placeholder="Search expenses..." />

    <br />

    <button type="submit" class="btn btn-primary">
        Search
    </button>
</form>

<br />

<form asp-action="Index" method="get">

    <div class="row">

        <div class="col-md-4">

            <input type="text"
                   name="searchTerm"
                   class="form-control"
                   placeholder="Search expenses..." />

        </div>

        <div class="col-md-2">

            <button type="submit"
                    class="btn btn-primary">
                Search
            </button>

        </div>

    </div>

</form>

<br />

<table class="table">
    <thead>
        <tr>
            <th>Description</th>
            <th>Amount</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var expense in Model)
        {
            <tr>
                <td>@expense.Description</td>
                <td>@expense.Value</td>
                <td>
                    <a asp-action="CreateEditExpense"
                       asp-route-id="@expense.Id"
                       class="btn btn-success">
                        Edit
                    </a>

                    <a asp-action="DeleteExpense"
                       asp-route-id="@expense.Id"
                       class="btn btn-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
